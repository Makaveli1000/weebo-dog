{
  "name": "projectsports",
  "version": "1.0.0",
  "description": "Zeus Portal Sports App",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node build-env.js && node esbuild.config.js && npm run tailwind:build && npm run copy:audio && npm run copy:html",
    "copy:html": "node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('src/index.html','dist/index.html'); if(fs.existsSync('src/assets')) fs.cpSync('src/assets','dist/assets',{recursive:true}); if(fs.existsSync('src/zeus-avatar.png')) fs.copyFileSync('src/zeus-avatar.png','dist/zeus-avatar.png');\"",
    "copy:audio": "node -e \"const fs = require('fs'); fs.mkdirSync('dist/audio', { recursive: true }); ['thunder.mp3', 'ambient.mp3'].forEach(f => { if(fs.existsSync('audio/' + f)) fs.copyFileSync('audio/' + f, 'dist/audio/' + f); });\"",
    "tailwind:build": "node ./node_modules/tailwindcss/lib/cli.js -i ./src/input.css -o ./dist/output.css --minify",
    "tailwind:watch": "npx tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "firebase": "^11.10.0",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "shx": "^0.3.4",
    "tailwindcss": "^3.4.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Makaveli1000/weebo-dog.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Makaveli1000/weebo-dog/issues"
  },
  "homepage": "https://github.com/Makaveli1000/weebo-dog#readme"
}