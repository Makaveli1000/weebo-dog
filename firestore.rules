rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // AUTH HELPERS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfileExists() {
      return isSignedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function userRole() {
      return userProfileExists()
        ? get(
            /databases/$(database)/documents/users/$(request.auth.uid)
          ).data.role
        : "fan";
    }

    function isAdmin() {
      return isSignedIn()
        && (
          userRole() == "admin"
          || userRole() == "editor"
        );
    }

    function isCoach() {
      return isSignedIn()
        && userRole() == "coach";
    }

    function isRecruiter() {
      return isSignedIn()
        && userRole() == "recruiter";
    }

    // ==========================================
    // USER PROFILES
    // ==========================================

    match /users/{userId} {

      allow read: if isSignedIn()
        && (
          request.auth.uid == userId
          || isAdmin()
        );

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role in [
          "fan",
          "athlete",
          "coach",
          "recruiter"
        ];

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            "nickname",
            "displayName",
            "photoUrl",
            "bio",
            "school",
            "sport",
            "state",
            "isPro",
            "premiumExpires",
            "tourCompleted",
            "updatedAt"
          ]);

      allow update, delete: if isAdmin();
    }

    // ==========================================
    // ATHLETES
    // ==========================================

    match /athletes/{athleteId} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // SPORTS FEED
    // ==========================================

    match /feedPosts/{postId} {

      allow read: if resource.data.status == "published"
        || (
          isSignedIn()
          && resource.data.uploaderId == request.auth.uid
        )
        || isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.uploaderId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.videoUrl is string
        && request.resource.data.title.size() > 0
        && request.resource.data.videoUrl.size() > 0
        && request.resource.data.likes == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.shareCount == 0
        && request.resource.data.saveCount == 0
        && request.resource.data.viewCount == 0
        && request.resource.data.likedBy.size() == 0
        && request.resource.data.savedBy.size() == 0
        && request.resource.data.status in [
          "draft",
          "published"
        ];

      // Owner can edit post content but cannot change ownership.
      allow update: if isSignedIn()
        && resource.data.uploaderId == request.auth.uid
        && request.resource.data.uploaderId
          == resource.data.uploaderId;

      // Signed-in users may update only shared engagement fields.
      allow update: if isSignedIn()
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            "likes",
            "likedBy",
            "commentCount",
            "shareCount",
            "saveCount",
            "viewCount",
            "reactions",
            "updatedAt"
          ])
        && request.resource.data.likes
          == request.resource.data.likedBy.size()
        && request.resource.data.likes >= 0
        && request.resource.data.commentCount >= 0
        && request.resource.data.shareCount >= 0
        && request.resource.data.saveCount >= 0
        && request.resource.data.viewCount >= 0;

      allow delete: if isSignedIn()
        && (
          resource.data.uploaderId == request.auth.uid
          || isAdmin()
        );

      // ========================================
      // FEED COMMENTS
      // ========================================

      match /comments/{commentId} {

        allow read: if true;

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300
          && request.resource.data.role in [
            "fan",
            "athlete",
            "coach",
            "recruiter",
            "admin"
          ];

        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId
            == resource.data.userId
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              "text",
              "updatedAt"
            ])
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;

        allow delete: if isSignedIn()
          && (
            resource.data.userId == request.auth.uid
            || isAdmin()
          );
      }
    }

    // ==========================================
    // SCHOOLS
    // ==========================================

    match /schools/{schoolId} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // MERCHANDISE / TEAM STORES
    // ==========================================

    match /merchandise/{productId} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // ZEUS REPORTS
    // ==========================================

    match /zeusReports/{reportId} {

      allow read: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || resource.data.recruiterId == request.auth.uid
          || isAdmin()
        );

      allow create: if isSignedIn()
        && (
          isRecruiter()
          || isCoach()
          || isAdmin()
        );

      allow update, delete: if isAdmin();
    }

    // ==========================================
    // RECRUITER NOTES
    // ==========================================

    match /recruiterNotes/{noteId} {

      allow create: if isSignedIn()
        && isRecruiter()
        && request.resource.data.recruiterId
          == request.auth.uid;

      allow read, update, delete: if isSignedIn()
        && (
          resource.data.recruiterId
            == request.auth.uid
          || isAdmin()
        );
    }

    // ==========================================
    // LIVE GAMES
    // ==========================================

    match /liveGames/{gameId} {

      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // DEFAULT DENY
    // ==========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}